{
  "ConnectionStrings": {
    "Gotcha2DBContext": "Server=.\\SQLEXPRESS;Database=Gotcha2.Db;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // JWT settings — used by the API to sign and validate tokens.
  // ASP.NET Core's JSON config reader allows // comments here.
  "Jwt": {
    // Dev-only signing key. Min 32 chars / 256 bits (HS256). For a real deployment,
    // override via env var (Jwt__Key) or user secrets — never reuse this committed value in prod.
    "Key": "QHYjBOLuCY3CUeOl6O8Zm04uMDMIeXJykvUSC4PZu28wzQyZK09YiSEmBGaWhxWW",

    // Issuer = who creates the token. The API itself.
    "Issuer": "Gotcha2.Api",

    // Audience = who the token is meant for. The MAUI client.
    "Audience": "Gotcha2.Maui",

    // Token lifetime in minutes. 480 = 8h, comfortable for a demo.
    "ExpiresInMinutes": 480
  },

  // CORS — exact-match origins allowed to call this API from a browser.
  // Server-side callers (the MAUI app) don't trigger CORS, but Swagger / browser tests on
  // a different host do. Add ports as needed.
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:7278",
      "http://localhost:5132"
    ]
  }
}
