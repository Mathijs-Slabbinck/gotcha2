<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Gotcha brand colors -->
    <Color x:Key="Primary">#5AD6DE</Color>            <!-- used by: SignIn (title text, card shadow), CheckBox color -->
    <Color x:Key="PrimaryDark">#3FBEC6</Color>        <!-- used by: default Button style (dark theme) -->
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>    <!-- used by: default Button style (dark theme) -->
    <Color x:Key="Secondary">#27BBC4</Color>          <!-- used by: SignIn (input borders) -->
    <Color x:Key="SecondaryDarkText">#27BBC4</Color>  <!-- used by: (none yet) -->
    <Color x:Key="Tertiary">#0E6B71</Color>           <!-- used by: SignIn (form labels, Sign-Up CTA bg, SecondaryButton text) -->

    <Color x:Key="Transparent">Transparent</Color>    <!-- used by: (none yet) -->
    <Color x:Key="White">White</Color>                <!-- used by: SignIn (input bg, SecondaryButton bg) -->
    <Color x:Key="Black">Black</Color>                <!-- used by: (none yet) -->
    <Color x:Key="OffBlack">#252729</Color>           <!-- used by: SignIn (page bg) -->
    <Color x:Key="DarkGray">#2E3033</Color>           <!-- used by: (none yet) -->
    <Color x:Key="CardBackground">#FFFFFF</Color>     <!-- used by: SignIn (card bg, card header bg) -->
    <Color x:Key="CyanTransparent">#405AD6DE</Color>  <!-- used by: (none yet) -->

    <Color x:Key="Danger">#D32F2F</Color>             <!-- used by: SignIn (error label) -->
    <Color x:Key="Success">#2E7D32</Color>            <!-- used by: (none yet — reserved for SignUp + success toasts) -->

    <Color x:Key="Gray100">#E1E1E1</Color>            <!-- used by: (none yet) -->
    <Color x:Key="Gray200">#C8C8C8</Color>            <!-- used by: SignIn (card separator BoxView) -->
    <Color x:Key="Gray300">#ACACAC</Color>            <!-- used by: (none yet) -->
    <Color x:Key="Gray400">#919191</Color>            <!-- used by: SignIn (entry placeholder text) -->
    <Color x:Key="Gray500">#6E6E6E</Color>            <!-- used by: (none yet) -->
    <Color x:Key="Gray600">#404040</Color>            <!-- used by: SignIn ("Remember me" label) -->
    <Color x:Key="Gray900">#212121</Color>            <!-- used by: SignIn (entry text) -->
    <Color x:Key="Gray950">#141414</Color>            <!-- used by: default BoxView style -->

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>          <!-- used by: SignIn (card Shadow Brush) -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>      <!-- used by: (none yet) -->
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>        <!-- used by: (none yet) -->
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>              <!-- used by: (none yet) -->
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>              <!-- used by: (none yet) -->

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>          <!-- used by: (none yet) -->
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>          <!-- used by: (none yet) -->
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>          <!-- used by: (none yet) -->
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>          <!-- used by: (none yet) -->
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>          <!-- used by: (none yet) -->
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>          <!-- used by: (none yet) -->
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>          <!-- used by: (none yet) -->
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>          <!-- used by: (none yet) -->
</ResourceDictionary>
